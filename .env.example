# SLDCS environment configuration template
# Copy to `.env` and fill in real values. `.env` is git-ignored and never committed.
# Every variable below is read by app/config.py (Settings) or the data scripts.
# Values here are safe placeholders/defaults only.

# Filesystem path to the active detection checkpoint.
# Leave blank to let Settings resolve the path from weights/model_registry.json
# (current_production). Set only to override the registry for a one-off run.
MODEL_PATH=

# Minimum detection confidence (0.0-1.0). Detections below this are discarded.
CONF_THRESHOLD=0.40

# Maximum accepted upload size in bytes (default 50 MB).
MAX_FILE_SIZE=52428800

# Application log verbosity: DEBUG, INFO, WARNING, ERROR, or CRITICAL.
LOG_LEVEL=INFO

# Enable FastAPI/uvicorn debug behaviour. Never enable in production.
DEBUG=false

# Path to the Google service-account or OAuth credentials JSON used by
# scripts/google_drive_sync.py to authenticate against the Drive API.
GOOGLE_DRIVE_CREDENTIALS_PATH=credentials/service_account.json

# ID of the Google Drive folder holding the 250 raw specimen images.
GOOGLE_DRIVE_FOLDER_ID=your-drive-folder-id-here
