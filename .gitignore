# SLDCS ignore rules
# Runtime output directories: keep the directory, ignore its contents.
logs/*
!logs/.gitkeep
uploads/*
!uploads/.gitkeep

# Python bytecode and build artifacts
__pycache__/
*.pyc
*.egg-info/
.pytest_cache/
.mypy_cache/

# Virtual environments
venv/
.venv/

# Environment secrets (never commit real values)
.env

# YOLOv5 default training/inference output directory — must never leak into VCS.
runs/

# Notebook checkpoints
.ipynb_checkpoints/

# OS cruft
.DS_Store

# NOTE: model weights (*.pt) under weights/ are intentionally NOT ignored.
# The pretrained checkpoint is tracked (or fetched via
# scripts/download_pretrained.py); see docs/SETUP.md for the size-based
# decision recorded in Step 11 of the build.
